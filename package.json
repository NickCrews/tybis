{
  "name": "tybis",
  "version": "0.1.0",
  "description": "Typesafe, portable dataframe library for TypeScript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "playground": "pnpm --filter tybis-playground dev",
    "playground:build": "pnpm build && pnpm --filter tybis-playground build",
    "playground:deploy": "pnpm playground:build && pnpm --filter tybis-playground deploy"
  },
  "keywords": ["dataframe", "sql", "prql", "typescript", "ibis"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.17",
    "expect-type": "^0.19.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "dependencies": {
    "prqlc": "^0.13.1"
  }
}
