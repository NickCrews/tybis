{
  "name": "tybis-monorepo",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "pnpm --recursive run lint",
    "build": "pnpm --recursive run build",
    "test": "pnpm --recursive run test",
    "typecheck": "pnpm --recursive run typecheck",
    "playground": "pnpm --filter tybis-playground dev",
    "playground:build": "pnpm --filter tybis build && pnpm --filter tybis-playground build",
    "playground:deploy": "pnpm playground:build && pnpm --filter tybis-playground deploy"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "core-js-pure",
      "workerd"
    ],
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  }
}